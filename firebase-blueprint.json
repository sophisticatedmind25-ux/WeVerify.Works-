{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "VideoAnalysis": {
      "title": "Video Analysis",
      "description": "Stores the results of a video analysis session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who performed the analysis" },
        "videoName": { "type": "string" },
        "analysis": { "type": "string", "description": "The text output from Gemini" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] }
      },
      "required": ["userId", "videoName", "analysis", "timestamp", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/analyses/{analysisId}": {
      "schema": "VideoAnalysis",
      "description": "Collection of video analysis results"
    }
  }
}

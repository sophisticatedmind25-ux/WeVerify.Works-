rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: analyses
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required, must match auth.uid)
    //   - videoName: string (required, < 255 chars)
    //   - analysis: string (required, < 10000 chars)
    //   - timestamp: timestamp (required)
    //   - status: string (required, enum: ['pending', 'completed', 'failed'])
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.createdAt is timestamp;
    }

    function isValidAnalysis(data) {
      return data.keys().hasAll(['userId', 'videoName', 'analysis', 'timestamp', 'status']) &&
             data.userId == request.auth.uid &&
             data.videoName is string && data.videoName.size() < 255 &&
             data.analysis is string && data.analysis.size() < 10000 &&
             data.timestamp is timestamp &&
             data.status in ['pending', 'completed', 'failed'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /analyses/{analysisId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidAnalysis(request.resource.data);
      allow update: if isDocOwner() && isValidAnalysis(request.resource.data);
      allow delete: if isDocOwner();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

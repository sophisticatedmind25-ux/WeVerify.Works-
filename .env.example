# SMTP Configuration (For Email Notifications)

# Option 1: Gmail (Requires App Password if 2FA is on)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Option 2: Outlook / Office 365
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@outlook.com
# SMTP_PASS=your-password

# Option 3: Custom / cPanel (Standard SSL)
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=support@yourdomain.com
# SMTP_PASS=your-password

# Active Configuration (Set these values)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="WeVerify Team" <no-reply@weverify.works>
